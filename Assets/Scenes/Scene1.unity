--- !u!114 &1591535449
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1591535448}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c904298384c5227469ab6bb7319828f5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ScScript
  steps:
  - type: 0
    ccscript: '{effect(fadein, Narrator)} {pause(1000)}@Look at these imbeciles its
      2026 and these kids are gonna ruin the world!{promt}'
    actor: {fileID: 693049173}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@They dont know it yet but It''ll happen!{promt}'
    actor: {fileID: 693049173}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@{sound(idea)}GUYS!{promt}'
    actor: {fileID: 1225456416}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@{effect(Turn1, Luke)}What Mahdi.{effect(turn1, Julian)} {effect(turn1,
      Cristian)}{promt}'
    actor: {fileID: 941091140}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@I feel like that trash can has somthing.{pause(500)}.{pause(500)}{promt}'
    actor: {fileID: 1225456416}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@Mahdi how much of an idiot are YOU!?{sound(julspam_loop)}{pause(2000)}'
    actor: {fileID: 1880406451}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '{sound(slap)}@Julian no one cares if you can say sneakers backward
      {promt}'
    actor: {fileID: 1449609101}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@AIEEEE :( {promt}'
    actor: {fileID: 1880406451}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@The idiot mahdi will now walk over too the trash can and i know it!
      {promt}'
    actor: {fileID: 693049173}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '{effect(walkTrash, Mahdi)}{pause(1500)}{sound(aquire)} **Mahdi found
      the "Button Of Doom"**{promt}'
    actor: {fileID: 1225456416}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@AHA!{pause(1000)} this is THE{pause(100)} doomsday device form yakub&skibob{promt}'
    actor: {fileID: 693049173}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '{effect(WalkBack, Mahdi)}{promt}'
    actor: {fileID: 1225456416}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@GUYS{pause(1000)} I FOUND A RESANONCE DISORDER DEVICE{promt}'
    actor: {fileID: 1225456416}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@Hes not wrong but its very bad it can destroy gravity!{promt}'
    actor: {fileID: 693049173}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@{sound(gasp))Dude what the hell was the for?!{pause(1000)} You ran
      and came back in like 3 seconds!{promt}'
    actor: {fileID: 941091140}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  - type: 0
    ccscript: '@Bro hes just fast Luke calm down{promt}'
    actor: {fileID: 1880406451}
    waitTime: 0
    requirePrompt: 0
    soundId: 
    effectId: 
  ui: {fileID: 1149054481}
  typeAudio: {fileID: 1131434498}
  typeClip: {fileID: 8300000, guid: 01549fad858fc7f4d8293c5209a988de, type: 3}
  effectController: {fileID: 1877266246}
  soundController: {fileID: 1331545098}
